# LM Studio local server (OpenAI-compatible)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model
LM_STUDIO_TIMEOUT_SECONDS=30

# Memory tier capacities
STM_MAX_TURNS=20
WM_MAX_RECORDS=50
LTM_MAX_RECORDS=10000

# Scoring weights (must sum to 1.0)
SCORE_WEIGHT_RELEVANCE=0.45
SCORE_WEIGHT_RECENCY=0.35
SCORE_WEIGHT_KEYWORD=0.20

# Routing thresholds
ROUTER_STM_THRESHOLD=0.85
ROUTER_WM_THRESHOLD=0.50
ROUTER_DISCARD_THRESHOLD=0.15

# Chunking
MAX_CHUNK_TOKENS_PROSE=256
MAX_CHUNK_TOKENS_CODE=512

# Assembly
DEFAULT_MAX_CONTEXT_TOKENS=8192
TOKEN_COUNT_PADDING_FACTOR=1.1

# Storage
DATA_DIR=~/.cce/data

# Server
HOST=127.0.0.1
PORT=8765
